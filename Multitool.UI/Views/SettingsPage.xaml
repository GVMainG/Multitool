<Page x:Class="Multitool.UI.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Настройки">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Настройки видимости инструментов" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20" />

        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20">
            <ItemsControl ItemsSource="{Binding Tools}" Margin="10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Name}" 
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <CheckBox Grid.Column="1" Content="Видимо" 
                                      IsChecked="{Binding IsVisible}" 
                                      VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Command="{Binding CancelCommand}" 
                    Padding="15,5" Margin="0,0,10,0" MinWidth="80" />
            <Button Content="Сохранить" Command="{Binding SaveCommand}" 
                    Padding="15,5" MinWidth="80" />
        </StackPanel>
    </Grid>
</Page>
